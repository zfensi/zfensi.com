---
import blogConfig from '../../blog.config.mjs';
import { toAbsoluteUrl } from '../lib/blog';

interface Props {
  title: string;
  description: string;
  canonicalPath: string;
  imagePath?: string;
  type?: 'website' | 'article';
}

const { title, description, canonicalPath, imagePath = blogConfig.defaultOgImage, type = 'website' } = Astro.props;
const canonical = toAbsoluteUrl(canonicalPath);
const ogImage = toAbsoluteUrl(imagePath);
const rssFeed = toAbsoluteUrl('/rss.xml');
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{title}</title>
<meta name="description" content={description} />
<meta name="theme-color" content="#081426" />
<link rel="canonical" href={canonical} />
<link rel="alternate" type="application/rss+xml" title={`${blogConfig.siteName} RSS Feed`} href={rssFeed} />
<link rel="icon" href="/favicon.ico" sizes="any" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />
<meta property="og:site_name" content={blogConfig.siteName} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content={type} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImage} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
<meta name="generator" content={Astro.generator} />
