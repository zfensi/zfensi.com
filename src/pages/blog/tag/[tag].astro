---
import { getCollection } from 'astro:content';
import ArticleCard from '../../../components/ArticleCard.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getTagUrl, sortPosts, type BlogEntry } from '../../../lib/blog';

export async function getStaticPaths() {
  const posts = sortPosts(await getCollection('blog'));
  const tags = [...new Set(posts.flatMap((post) => post.data.tags))];

  return tags.map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: posts.filter((post) => post.data.tags.includes(tag)),
    },
  }));
}

interface Props {
  tag: string;
  posts: BlogEntry[];
}

const { tag, posts } = Astro.props;
---

<BaseLayout
  title={`标签：${tag}`}
  description={`标签 ${tag} 下的文章归档页面。`}
  canonicalPath={getTagUrl(tag)}
>
  <section class="hero">
    <p class="section-note"><a href="/blog.html">文章</a> / 标签</p>
    <h1 class="page-title">#{tag}</h1>
    <p class="page-intro">该标签下共有 {posts.length} 篇文章。</p>
  </section>

  <section class="grid grid--cards">
    {posts.map((post) => <ArticleCard post={post} />)}
  </section>
</BaseLayout>
